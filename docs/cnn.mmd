graph LR
    subgraph INPUT["Input: 24h × 5 features"]
        I1["Carbon Intensity"]
        I1 --> I2
        I2["hour_sin, hour_cos"]
        I2 --> I3
        I3["year_sin, year_cos"]
    end

    subgraph CNN["CNN Model (99K params)"]
        C1["Conv1D<br/>64 filters, kernel=3, ReLU<br/>(24,5) → (22,64)"]
        C2["Conv1D<br/>32 filters, kernel=3, ReLU<br/>(22,64) → (20,32)"]
        F["Flatten<br/>(20,32) → (640)"]
        D1["Dense 128 + ReLU<br/>Dropout 0.3"]
        D2["Dense 64 + ReLU<br/>Dropout 0.3"]
        D3["Dense 24<br/>(output layer)"]
    end

    subgraph OUTPUT["Output: 24 predictions"]
        O1["Hour 1: 45.2 gCO₂/kWh"]
        O1 --> O2
        O2["Hour 2: 42.8 gCO₂/kWh"]
        O2 --> O3
        O3["Hour 24: 78.1 gCO₂/kWh"]
        O4["..."]
        O3 --> O4
    end

    INPUT --> C1
    C1 --> C2
    C2 --> F
    F --> D1
    D1 --> D2
    D2 --> D3
    D3 --> OUTPUT

    style INPUT fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style CNN fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style OUTPUT fill:#fff3e0,stroke:#e65100,stroke-width:2px